  /**
   * Check or uncheck lines
   * @return	Array
   */
  checkbox: function (status) {
    // Cochage
    if (status) {
      $(this.element)
        .find(".table-body input[type=checkbox]:visible:not(:checked)")
        .prop("checked", true)
        .trigger("change");
      this.options.allDisplayedAreChecked = true;
    }
    // Décochage
    else {
      $(this.element)
        .find(".table-body input[type=checkbox]:checked")
        .prop("checked", false)
        .trigger("change");
      this.options.allDisplayedAreChecked = false;
    }
  },

  /**
   * Scroll infini
   */
  infiniteScroll: function (force) {
    if (this._infiniteScrollRunning) {
      return;
    }
    // Nombre de lignes dans le tableau
    var nbLines = Object.keys(this.options.data).length;
    if (
      // Une source existe
      this.options.truncatedScrollCallback &&
      // Le tableau n'est pas vide ou mode forcé (permet d'éviter un chargement intempestif si rien n'est prêt)
      (nbLines || force) &&
      // Il reste des lignes à ajouter
      this.options.truncatedNb &&
      (this.options.truncatedNb > nbLines || this.options.truncatedNb === -1)
    ) {
      var widget = this;
      this._infiniteScrollRunning = true;
      // Appel du callback
      this.options.truncatedScrollCallback(function (lines, callback) {
        // Ajout des lignes
        widget.adds(lines, function () {
          // Arrêt
          widget._infiniteScrollRunning = false;
          // Callback éventuel
          if (callback) {
            callback();
          }

          if (widget.options.statuses.sorted && !$('#partialSorting').length) {
            _spark.template.notificationMessage(
                trans('spark.template.table.warning.partialSorting'),
                'warning',
                {
                  id: 'partialSorting',
                  delay: 5000,
                }
            );
          }
        });
      });
    }
  },

  /**
   * Remove a line
   * @param	{string}	lineId		Identifiant de la ligne à retirer
   */
  remove: function (lineId) {
    this.setTableStatus('sorted', false);

    // Une ligne est spécifiée
    if (lineId) {
      var widget = this;
      // Retrait du DOM avec un effet slideUp
      $(this.element)
        .find(".table-ln[data-id='" + lineId + "']")
        .slideUp("slow", function () {
          $(this).remove();
          // Actualise le nombre de lignes
          widget._count();
        });
      // Retrait du JS
      delete this.options.data[lineId];
    }
    // On retire toutes les lignes
    else {
      // Retrait du DOM sans effet slideUp car ça peut faire freezer le navigateur
      $(this.element).find(".table-ln.table-body").remove();
      // Retrait du JS
      this.options.data = {};
      // Actualise le nombre de lignes
      this._count();
    }
  },

  /**
   * Affiche une ligne
   * @param	{string}	lineId		Identifiant de la ligne à afficher
   */
  show: function (lineId) {
    this.toggle(lineId, true);
  },

  /**
   * Tri du tableau
   */
  sort: function (field, asc) {
    this.setTableStatus('sorted', true);
    var rows = [];
    var keys = Object.keys(this.options.data);
    for (var i = 0; i < keys.length; i++) {
      rows.push([keys[i], this.options.data[keys[i]][field]]);
    }
    rows.sort(function (a, b) {

      // 2 valeurs de date
      var dateA = getDateFromCellValue(a[1]);
      var dateB = getDateFromCellValue(b[1]);

      if (!isNaN(dateA) && !isNaN(dateB)) {
        return dateA.getTime() - dateB.getTime();
      }

      // 2 valeurs numériques
      if ($.isNumeric(a[1]) && $.isNumeric(b[1])) {
        return a[1] - b[1];
      }
      // On les considères comme du texte
      var _a, _b;
      if (a[1] === null || a[1] === undefined) {
        _a = "";
      } else if (typeof a[1] === "string") {
        _a = a[1];
      } else {
        _a = a[1].toString();
      }
      if (b[1] === null || b[1] === undefined) {
        _b = "";
      } else if (typeof b[1] === "string") {
        _b = b[1];
      } else {
        _b = b[1].toString();
      }
      // Comparaison
      return _a.localeCompare(_b);
    });
    if (asc === false) {
      rows = rows.reverse();
    }
    for (i = 0; i < rows.length; i++) {
      var spacelessId = rows[i][0].length
        ? rows[i][0].replace(/\s/g, "")
        : rows[i][0];
      this.element.append($("#" + this.options.id + "Table_" + spacelessId));
    }
  },

  /**
   * Affiche ou masque une ligne
   */
  toggle: function (lineId, visible) {
    var self = this;
    if (lineId) {
      this.options.data[lineId]._visible = visible;
      var line = $(this.element)
        .find(".table-ln[data-id='" + lineId + "']")
        .toggle(visible);
      if (!visible) {
        // Décoche les lignes masquées
        line
            .find("input[type=checkbox]:checked")
            .prop("checked", false)
            .trigger("change");
      }
    } else {
      $.each(this.options.data, function (_lineId) {
        self.options.data[_lineId]._visible = visible;
      });
      $(this.element).find(".table-ln").toggle(visible);
    }
    // Update the count
    this._count();
  },

  _buttonsDisabledToggle: function () {
    var linesNb = $(this.element)
      .find(".table-body")
      .find("[type=checkbox]:checked").length;
    if (linesNb) {
      $("." + this.options.id + "TableButtons").removeClass("disabled");
    } else {
      $("." + this.options.id + "TableButtons").addClass("disabled");
    }
  },

  setTableStatus: function(status, toggle) {
    // Change status
    this.options.statuses[status] = toggle;

    for (var entry of Object.entries(this.options.statuses)) {
      $('#' + this.options.id + 'TableWrapper').attr('data-' + entry[0], entry[1]);
    }
  },

  /**
   * Compte le nombre de lignes
   */
  _count: function () {
    var self = this;
    var nbHidden = Object.keys(this.options.data).filter(function (key) {
      return self.options.data[key]._visible === false;
    }).length;
    var nbTotal;
    var nbDisplayed = Object.keys(this.options.data).length - nbHidden;
    var nbChecked = $(this.element)
      .find(".table-body")
      .find("[type=checkbox]:checked").length;
    var DOM = $(this.element).parents(".tableWrapper").find(".tableLinesNb");
    // Des lignes sont sélectionnées

    this.setTableStatus(
        'truncated',
        nbDisplayed > 0 && this.options.truncatedNb > 0 && this.options.truncatedNb !== nbDisplayed
    );

    if (nbChecked) {
      if (this.options.truncatedNb === -1) {
        DOM.text(
          trans("spark.template.table.count.checked.untruncated", {
            nbChecked: nbChecked,
          })
        );
      } else if(!this.options.truncatedChecked) {
        if (this.options.truncatedNb) {
          nbTotal = this.options.truncatedNb;
        } else {
          nbTotal = nbDisplayed;
        }
        DOM.text(
          trans("spark.template.table.count.checked.truncated", {
            nbChecked: nbChecked,
            nbTotal: nbTotal,
          })
        );
      }
      // Tout sélectionner
      if (
        // On connait le nombre réel de lignes
        this.options.truncatedNb &&
        // Il y a des lignes masquées
        (this.options.truncatedNb > nbDisplayed ||
          this.options.truncatedNb === -1) &&
        // Toutes les lignes sont sélectionnées
        nbChecked === nbDisplayed &&
        // We can select all lines (even the ones not in the table)
        this.options.truncatedCheckable
      ) {
        if ($('#searchTableHeaderCheckbox').prop('checked') === false) {
          // Force batch selector to be checked
          $('#searchTableHeaderCheckbox').prop('checked', true).trigger('change');
        }
        $('.checkAllAlert').remove();
        var widget = this;
        DOM.append(
          " ",
          $("<div>")
            .addClass("cursorPointer backgroundLarge backgroundBlueLight checkAllAlert")
            .append(
              this.options.truncatedNb === -1
                ? trans(
                    "spark.template.table.count.checked.all.buttonUntruncated",
                    {
                      nbDisplayed: nbDisplayed,
                    }
                  )
                : trans("spark.template.table.count.checked.all.button", {
                    nbDisplayed: nbDisplayed,
                    truncatedNb: this.options.truncatedNb,
                  })
            )
            .on("click", function () {
              // Persists the fact that all lines are selected
              widget.options.truncatedChecked = true;
              // Updates the message
              DOM.text(trans("spark.template.table.count.checked.all.text"));
              // Force batch selector to be checked
              $('#searchTableHeaderCheckbox').prop('checked', true);
            })
        );
      }
    } else if (nbDisplayed === 0) {
      DOM.text(trans("spark.template.table.count.displayed.empty"));
    } else if (
      this.options.truncatedNb &&
      this.options.truncatedNb > nbDisplayed
    ) {
      DOM.text(
        trans("spark.template.table.count.displayed.truncated", {
          nbDisplayed: nbDisplayed,
          truncatedNb: this.options.truncatedNb,
        })
      );
    } else if (this.options.truncatedNb && this.options.truncatedNb === -1) {
      DOM.text(
        trans("spark.template.table.count.displayed.untruncated", {
          nbDisplayed: nbDisplayed,
        })
      );
    } else {
      DOM.text(
        trans("spark.template.table.count.displayed.rows", {
          nbDisplayed: nbDisplayed,
        })
      );
    }
    // Reset des lignes masquées
    this.options.truncatedIds = null;
  },

  /**
   * Applique les filtres et retourne la valeur
   * Cette fonction retourne toujours une chaine safe du point de vue XSS
   */
  _eachValue: null,
  _filters: function (filters, value, data, dataKey, safeXSS) {
    var date, month, day, i, j;
    // Récupération des clefs au cas où filters est un objet et pas un tableau
    if (typeof filters !== "object") {
      filters = [filters];
    }
    var keys = Object.keys(filters);
    for (i = 0; i < keys.length; i++) {
      // Equivalent de [PHP] foreach($filters as $filter => $filterData)
      var filter = keys[i];
      var filterData = filters[filter];
      // 2 possibilité d'écrire un filtre
      // [array index]	=> datetime
      // append			=> [élement à ajouter]
      if ($.isNumeric(filter)) {
        filter = filterData;
        filterData = null;
      }
      var result;
      switch (filter) {
        // Ecrit une valeur après le texte
        case "append":
          // Protection XSS
          value = this._xss(value, safeXSS);
          if (typeof filterData === "string") {
            result = this._value(filterData, data);
            if (result === null) {
              // On ajoute ce qui a déjà été traité
              value += _spark.xss(filterData);
            } else {
              // Filtre XSS obligatoire car la valeur vient de l'objet
              value += _spark.xss(result);
            }
          } else if (typeof filterData === "object") {
            // A priori nouveau contenu donc le filtre XSS doit être appliqué
            value += this._filters(filterData, value, data, dataKey, false);
          } else {
            // Contenu inconnu donc on applique le filtre
            value += _spark.xss(filterData);
          }
          safeXSS = true;
          break;
        // Date au format JJ/MM/YYYY
        case "date":
          if (value) {
            if (typeof value !== "string") {
              value = value.toString();
            }
            data[dataKey + "Date"] = value;
            if (value.indexOf('/') === -1) {
              value = transDateFromYMD(value);
            }
            // Protection XSS
            value = value.xss();
          } else {
            value = "";
          }
          safeXSS = true;
          break;
        case "each":
          // This new variable helps to keep the data var intact
          // as "value[j] = ..." would modify the actual variable (vs writing in a new memory slot)
          var newValue = [];
          for (j = 0; j < value.length; j++) {
            this._eachValue = value[j];
            newValue[j] = this._filters(
              filterData,
              value[j],
              data,
              dataKey,
              false
            );
          }
          value = newValue;
          safeXSS = true;
          break;
        case "eachValue":
          value = _spark.xss(this._eachValue);
          safeXSS = true;
          break;
        // Pour les icones
        case "ico":
          var ico, color, title;
          // Pas de couleur indiquée
          if (typeof filterData === "string") {
            filterData = [filterData, "dark"];
          } else {
            if (filterData.length === 1) {
              filterData.push("dark");
            }
            if (filterData.length === 2) {
              filterData.push("");
            }
          }
          // Ico constante
          if (typeof filterData[0] === "string") {
            ico = filterData[0];
            color = filterData[1];
            title = filterData[2];
            className = filterData[3];
          }
          // Icone qui dépend de la valeur
          else if (typeof filterData[0] === "object") {
            // Si la valeur n'est pas dans le tableau, on n'affiche rien
            if (value in filterData[0]) {
              if (typeof filterData[0][value] === "object") {
                ico = filterData[0][value][0];
                color = filterData[0][value][1];
                title = filterData[0][value][2];
                className = filterData[0][value][3];
              } else {
                ico = filterData[0][value];
                color = filterData[1];
                title = "";
                className = ""
              }
            }
          }
          if (ico) {
            // _spark.template._gif gère la protection XSS
            value = _spark.template._gif(
              "ico" + ico.ucfirst() + "16" + color.ucfirst() + " " + className,
              null,
              null,
              title
            )[0].outerHTML;
          } else {
            value = "";
          }
          safeXSS = true;
          break;
        // Ajoute une image
        case "image":
          if (typeof filterData[1] === "undefined") {
            filterData[1] = 0;
          }
          if (typeof filterData[2] === "undefined") {
            filterData[2] = 0;
          }
          value =
            '<img src="' +
            this._filters(filterData[0], value, data, dataKey) +
            '" width="' +
            filterData[1].toString().xss() +
            '" height="' +
            filterData[2].toString().xss() +
            '">';
          safeXSS = true;
          break;
        case "input-checkbox":
          var _value = this._xss(this._value(this.options.key, data), safeXSS);
          var id = this.options.id + "Table_input_checkbox" + _value;
          // Protection
          id = id.xss();
          // Contenu
          var content =
            '<label for="' +
            id +
            '" class="checkbox" id="' +
            this.options.id +
            "Table_label" +
            _value +
            '">';
          content +=
            '<input data-toggle="checkbox" type="checkbox" name="' +
            this.options.id +
            'Table[]" id="' +
            id +
            '" value="' +
            _value +
            '"' +
            (this.options.allDisplayedAreChecked ? 'checked="checked"' : "") +
            ">";
          content += "<span>" + this._xss(value, safeXSS) + "</span>";
          content += "</label>";
          _spark.inDOM("#" + id, function (element) {
            element.radiocheck();
          });
          value = content;
          safeXSS = true;
          break;
        // Jointure de plusieurs valeurs
        case "join":
          if (typeof filterData === "string") {    if (value) {
              value = this._xss(value.join(filterData), safeXSS);
            } else {
              value = ""; // Added for when algolia doesn't have the parameter $structures in /organisation/membres/export
            }
          } else {
            // Application des filtres
            result = [];
            for (j = 1; j < filterData.length; j++) {
              result.push(
                this._xss(
                  this._filters(filterData[j], value, data, dataKey, false)
                )
              );
            }
            value = result.join(this._xss(filterData.slice(0, 1)));
          }
          safeXSS = true;
          break;
        // Lien mailto:
        // TODO Sylvain : Remplacer par email
        case "mail":
          value = _spark.template.format(value, _spark.template.FORMAT_EMAIL);
          safeXSS = true;
          break;
        // Ajout du symbole monétaire
        case "money":
          value = window.transCurrency(value);
          safeXSS = true;
          break;
        // Ajout du symbole %
        case "percent":
          value = Math.round(value) + " %";
          value = value.xss();
          safeXSS = true;
          break;
        // Mise sous forme de pourcentage
        case "percent100":
          value = Math.round(value * 100) + " %";
          value = value.xss();
          safeXSS = true;
          break;
        // Lien téléphone
        case "phone":
          if (value) {
            value = _spark.template.format(value, _spark.template.FORMAT_PHONE);
            safeXSS = true;
          }
          break;
        // Ecrit une valeur avant le texte
        case "prepend":
          // Protection XSS
          value = this._xss(value, safeXSS);
          if (typeof filterData === "string") {
            result = this._value(filterData, data);
            if (result === null) {
              // On ajoute ce qui a déjà été traité
              value = _spark.xss(filterData) + value;
            } else {
              // Filtre XSS obligatoire car la valeur vient de l'objet
              value = _spark.xss(result) + value;
            }
          } else if (typeof filterData === "object") {
            // A priori nouveau contenu donc le filtre XSS doit être appliqué
            value =
              this._filters(filterData, value, data, dataKey, false) + value;
          } else {
            // Contenu inconnu donc on applique le filtre
            value = _spark.xss(filterData) + value;
          }
          safeXSS = true;
          break;
        // Ecrit un texte valable pour toutes les lignes (indépendant de value)
        case "text":
          value = this._xss(filterData, safeXSS);
          safeXSS = true;
          break;
        // Timestamp au format JJ/MM/YYYY à HH:MM:SS
        case "timestamp":
          if (value) {
            date = new Date(value * 1000);
            value = window.transDateTime(date);
            // Protection XSS
            value = value.xss();
          } else {
            value = "";
          }
          safeXSS = true;
          break;
        // Timestamp au format JJ/MM/YYYY
        case "timestamp-date":
          if (value) {
            date = new Date(value * 1000);
            value = window.transDate(date);
            // Protection XSS
            data[dataKey + "Date"] = value;
            if (value.indexOf('/') === -1) {
              if (I18N_LOCALE === "en-US") {
                value = value.substr(4, 2)
                    + "/"
                    + value.substr(6, 2)
                    + "/"
                    + value.substr(2, 2)
                ;
              } else {
                value = value.substr(6, 2)
                    + "/"
                    + value.substr(4, 2)
                    + "/"
                    + value.substr(0, 4)
                ;
              }
            }
            value = value.xss();
          } else {
            value = "";
          }
          safeXSS = true;
          break;
        // Affiche une url
        case "url":
          var url;
          // Fix #11085
          if (value === null) {
            value = "";
          }
          if (filterData) {
            url = this._filters(filterData, value, data, dataKey);
          } else {
            url = value.xss();
          }
          if (url) {
            value =
              '<a href="' +
              _spark.fixUrl(url, false) +
              '">' +
              this._xss(value, safeXSS) +
              "</a>";
            safeXSS = true;
          }
          break;
        // Affiche la valeur de la data demandé
        case "value":
          value = this._value(filterData, data);
          // Protection XSS
          if (value === null) {
            value = "";
          } else {
            value = value.toString().xss();
            safeXSS = true;
          }
          break;
        // Affiche la valeur de la clef value dans le tableau filterData
        case "values":
          if (value !== null && value !== undefined) {
            if ($.isArray(value) === false) {
              value = [value];
            }
            result = [];
            for (j = 0; j < value.length; j++) {
              result.push(filterData[value[j]]);
            }
            value = result.join(", ").xss();
            safeXSS = true;
          }
          break;
        // Cas par défaut
        default:
          // Si le filtre est un tableau - on refait une passe sur le filtre
          if ($.isPlainObject(filterData)) {
            value = this._filters(filterData, value, data, dataKey, false);
            safeXSS = true;
          } else if ($.isPlainObject(filter)) {
            value = this._filters(filter, value, data, dataKey, false);
            safeXSS = true;
          } else if (typeof filter === "string") {
            value = this._value(filter, data);
          }
          break;
      }
    }
    // Protection XSS & Retour
    return this._xss(value, safeXSS);
  },

  /**
   * Largeur du tableau (et de la scrollbar du haut)
   */
  _tableWidth: function () {
    var element = $(this.element);
    // Tableau visible
    if (element.parents(".tableWrapper").is(":visible")) {
      var width = 0;
      for (var key in this.options.toggleColumnsStatus) {
        if (
          this.options.toggleColumnsStatus.hasOwnProperty(key) &&
          this.options.toggleColumnsStatus[key]
        ) {
          width =
            width +
            element
              .find(".table-header")
              .find("div[class*='-" + key + "']")
              .outerWidth();
        }
      }
      // Largeur du tableau
      element.css("width", width + "px");
      // Largeur de la scrollbar du haut
      $("#" + this.options.id + "TableScrollbar").css("width", width + "px");
      // Supprime la classe d'initialisation du tableau (elle cache le tableau et permet d'éviter un double calcul de la hauteur de la page)
      if (element.hasClass("tableInit")) {
        element.removeClass("tableInit");
      }
      // Position automatique de la colonne fixe au chargement du tableau
      var tableFixedColumnDOM = $("." + this.options.id + "TableFixedColumn");
      tableFixedColumnDOM.css({
        right: "auto",
        left:
          $("#" + this.options.id + "TableScroll").width() +
          $("#" + this.options.id + "TableScrollbarWrapper").scrollLeft() -
          tableFixedColumnDOM.outerWidth(),
      });
    }
    // Tableau masqué
    else {
      // Récursivité tant que le tableau n'est pas visible
      var widget = this;
      window.setTimeout(function () {
        widget._tableWidth();
      }, 50);
    }
  },

  /**
   * Retourne la valeur associée à une clef d'un objet
   * Retourne null si la clef n'existe pas
   */
  _value: function (name, object) {
    if (name in object) {
      return object[name];
    } else {
      return null;
    }
  },

  _xss: function (value, safeXSS) {
    if (safeXSS) {
      return value;
    } else {
      return _spark.xss(value);
    }
  },
});

/**
 * Toggle an element on the page
 *
 * Both show and hide controllers:
 * <p class="toggleMore" data-toggle-content="[id of content]" data-toggle-hide="[id of hiding controller]">Show</p>
 * <p id="[id of hiding controller]">Hide</p>
 * <div id="[id of content]">Content</div>
 *
 * Only show controller:
 * <p class="toggleMore" data-toggle-content="[id of content]">Show</p>
 * <div id="[id of content]">Content</div>
 *
 */

$(window).on("load", function() {
    $(".toggleMore[data-toggle-content]").each(function(){
        var showDOM = $(this);
        var hideDOM = $("#" + $(this).data("toggleHide"));
        var contentDOM = $("#" + $(this).data("toggleContent"));
        // Content is hidden
        contentDOM.hide();
        // Action on show controller
        showDOM.on("click", function(){
            // There is an element to hide the content
            if(hideDOM.length){
                // Toggle controllers
                showDOM.toggle();
                hideDOM.toggle();
                // Show the content
                contentDOM.slideDown();
            }
            // There is no element to hide the content: the controller is used for both showing and hiding content
            else{
                contentDOM.slideToggle();
            }
        });
        // The content is hidden on click on hide controller
        hideDOM
            .hide()
            .addClass("toggleMore")
            .on("click", function(){
                // Toggle the controllers
