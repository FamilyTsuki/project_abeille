function getDateFromCellValue(str) {
  if (typeof str !== 'string') {
    return undefined
  }

  if (I18N_LOCALE !== 'fr-FR') {
    return new Date(str);
  }

  if (
      str.length !== 10
      || str.match(new RegExp("/", "g")) === null
      || str.match(new RegExp("/", "g")).length !== 2
  ) {
    return undefined
  }

  var dateStr = str.split('/');
  if (dateStr.length !== 3) {
    return undefined;
  }

  return new Date(+dateStr[2], dateStr[1] - 1, +dateStr[0]);
}

