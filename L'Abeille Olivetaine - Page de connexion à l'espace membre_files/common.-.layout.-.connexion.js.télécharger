  initMailGroup: function(formId) {
    if ($('#' + formId + 'Form').find('.mailGroupWrapper').length) {
      var MAX_SECONDARIES = 4;
      $('.emailAction').on("click", function() {
        var mailGroup = $(this).closest('.mailGroupWrapper');

        if ($(this).hasClass('add')) {
          var nb = mailGroup.find('.isSecondaryWrapper.visible').length;
          if (0 === nb) {
            mailGroup.find('.isPrimaryWrapper').removeClass('last');
            mailGroup.find('.isSecondaryWrapper').addClass('visible last');
          } else {
            var secondaries = mailGroup.find('.isSecondaryWrapper');

            if (secondaries.length >= MAX_SECONDARIES - 1) {
              $(secondaries[secondaries.length - 1]).removeClass('last');
            }

            var clone = $(secondaries[secondaries.length - 1])
                .clone(true)
                .appendTo(mailGroup.find('.secondaryEmailsWrapper'));
            clone.find('input').val('');

            if (secondaries.length < MAX_SECONDARIES - 1) {
              $(secondaries[secondaries.length - 1]).removeClass('last');
            }
          }
        } else {
          var secondary = $(this).closest('.isSecondaryWrapper');
          if (1 === mailGroup.find('.isSecondaryWrapper').length) {
            mailGroup.find('.isPrimaryWrapper').addClass('last');
            secondary.removeClass('last visible');
            secondary.find('input').val('');
          } else {
            secondary.remove();
            var secondaries = mailGroup.find('.isSecondaryWrapper');
            secondaries.removeClass('last');
            $(secondaries[secondaries.length - 1]).addClass('last');
          }
