    query: function(){
        // Pending request
        if(this.options.active && this.ajaxStatus() === XMLHttpRequest.DONE){
            var widget = this;
            // Loading
            this.loading.show();
            // Query
            var data;
            if(typeof this.options.ajaxData === "function"){
                data = this.options.ajaxData();
            }
            else if(this.options.ajaxData){
                data = this.options.ajaxData;
            }
            else{
                data = {};
            }
            data.offset = this.element.children().length;
            this.ajax = $.ajax({
                url: this.options.ajaxURL,
                type: this.options.ajaxType,
                data: data,
                success: function(response) {
                    // Loading
                    widget.loading.hide();
                    if (response.length) {
                        // Post processing
                        if (widget.options.postProcess) {
                            response = widget.options.postProcess(response);
                        }
                        // Append
                        widget.element.append(response);
                        // Callback
                        if(widget.options.postCallback){
                            widget.options.postCallback();
                        }
                        // New query if last element is visible
                        widget.handler();
                    }
                    // Empty set
                    else {
                        // No more query as there is no content left
                        widget.options.active = false;
                    }
                }
            });
        }
    }
});
