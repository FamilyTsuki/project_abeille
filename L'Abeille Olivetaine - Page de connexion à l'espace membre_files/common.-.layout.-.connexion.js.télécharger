	var notice = $(".notice:not(:empty):first");
	// On filtre sur l'id pour ne pas tenir compte des petites erreurs que l'on ajoute dans la page avec une simple classe
	if(notice.length && notice.attr("id")) {
		return $("html, body").scrollTo("#" + notice.attr("id"), {offsetTop: 100});
	}
});

/**
 * Aller à la notice suivante/précédente
 */
$(function() {
	var notices = $(".notice:not(:empty)");
	var i = 0; // 0 et pas -1 pour sauter la première notice

	$(".nextNotice").on("click", function() {
		if(i < notices.length - 1) {
			i++;
			// Si la notice n'est pas visible essai de trouver un accordéon parent non visible afin de le déplier
			var noticeDOM = $("#" + notices[i].id);
			if(
				noticeDOM.is(":visible") === false
				&& noticeDOM.parents(".accordionOpen").length
				&& noticeDOM.parents(".accordionOpen").is(":visible") === false
			) {
				noticeDOM.parents(".accordionContent").find(".accordionTitleWrapper").trigger("click");
			}
			// Défile vers la notice
			return $("html, body").scrollTo("#" + notices[i].id, {offsetTop: 100});
		}
	});
	$(".prevNotice").on("click", function() {
		if(i > 0) {
			i--;
			// Si la notice n'est pas visible essai de trouver un accordéon parent non visible afin de le déplier
			var noticeDOM = $("#" + notices[i].id);
			if(
				noticeDOM.is(":visible") === false
				&& noticeDOM.parents(".accordionOpen").length
				&& noticeDOM.parents(".accordionOpen").is(":visible") === false
			) {
				noticeDOM.parents(".accordionContent").find(".accordionTitleWrapper").trigger("click");
			}
			// Défile vers la notice
			return $("html, body").scrollTo("#" + notices[i].id, {offsetTop: 100});
		}
	});
});
/**
 * Inscription à la newsletter
 */
$(function () {
  $(".newsletterRegister").on("submit", function (event) {
    event.preventDefault();
    // Check l'adresse email
    var email = $(this).find("input[type='email']").val();
    if (email === "") {
      _spark.template.alert(trans("registration.addMail"));
    } else {
      // Chargement
      _spark.template.loading(true);
      // Requête
      _spark.ajax({
        url: "/emailing/ajax.newsletter.php",
        type: "POST",
        data: {
          email: email,
        },
        success: function (response) {
          // Chargement
          _spark.template.loading(false);
          // Succès
          if (response.result) {
            // Redirection
            if (response.register) {
              _spark.redirect(
                "/contacts/registration?mode=newsletter&redirect=" +
                  URI_CLIENT +
                  "&email=" +
                  email
              );
            }
            // Message
            else {
              // Modal Newsletter
              var newsletterDialog = $("div#newsletterDialog");
              if (newsletterDialog.is(":visible") === true) {
                newsletterDialog.dialog("close");
              }
              _spark.template.alert(trans("registration.addedMail"));
            }
          }
          // Echec
          else {
            if (response.alreadyInList) {
              _spark.template.alert(trans("registration.mailAlreadyExisting"));
            } else {
              _spark.template.alert(trans("registration.failed"));
            }
          }
        },
      });
    }
    // Pas de soumission du formulaire
    return false;
  });
});

/**
 * Ajout des espaces insécables
 * Source : http://www.bennadel.com/blog/2253-replacing-text-nodes-with-jquery.htm
 */
$(document).ready(function(){
	// Liste des balise à traiter
	var textNodes = $("p, div, b, i, em, strong, a, li, span, h1, h2, h3, h4, h5, h6")
		.contents()
		.filter(function() {
			// Ne traite que le texte des balises et pas les balises enfants
			return (this.nodeType === 3);
		});

	// Remplace les espaces
	textNodes.each(function() {
		this.nodeValue = this.nodeValue
			.replace(/ ;/g,		"\xa0;")
			.replace(/ \?/g,	"\xa0?")
			.replace(/ !/g,		"\xa0!")
			.replace(/ :/g,		"\xa0:")
			.replace(/« /g,		"«\xa0")
			.replace(/ »/g,		"\xa0»")
	});
});
