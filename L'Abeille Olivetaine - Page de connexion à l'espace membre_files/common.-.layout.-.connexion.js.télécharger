 */
_spark.template._gif = function(css, id, alt, title) {
  let _css = css.split(" ");
  if (!0 in _css) {
    // error
    return;
  }
  let image = _css[0];

  let iconName = "";
  if (image.substr(0, 3) === "ico" || image.substr(0, 4) === "yado") {
    iconName = image.replace(/([A-Z]|[0-9]+)/g, function(match) {
      if (/[0-9]{3}/.test(match)) {
        return (
          match[0].toLowerCase() + "." + (match[1] + match[2]).toLowerCase()
        );
      } else {
        return "." + match.toLowerCase();
      }
    });
  } else {
    // error
    return;
  }

  let icoPath = "/common/ico/" + iconName + ".png";

  return $("<img>")
    .attr("src", "https://webcdnprodas-software-f0h9ewgjhra7effp.z01.azurefd.net/legacy" + icoPath)
    .attr("id", id)
    .attr("alt", alt)
    .attr("title", title)
    .addClass("_gif " + css);
};

