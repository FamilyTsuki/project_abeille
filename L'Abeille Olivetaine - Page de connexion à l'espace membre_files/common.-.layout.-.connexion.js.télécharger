 */
$.widget("buypacker.formUploadPicture", $.spark.formUpload, {
	/**
	 * Widget creation
	 */
	_create: function(){
		this.options.action = "/ajax/form/ajax.upload.picture.php";
		return this._super();
	},

	/**
	 * Vérification
	 */
	_checker: function(file, success, error){
		var widget = this;
		// Vérification de base du parent
		this._super(file, function(){
			var reader = new FileReader();
			reader.onload = function(event) {
				var image = new Image();
				image.onload = function() {
					// Mode strict ou modes spécifiques
					if(widget.options.uploadData.strict) {

						var widthMax;
						var heightMax;
						var widthMin;
						var heightMin;

						// Image standard
						if(widget.options.uploadData.size === SIZE_STANDARD) {
							widthMin = THUMB_WIDTH;
							heightMin = THUMB_HEIGHT;
						}
						// Image utilisateur
						else if(widget.options.uploadData.size === SIZE_USER) {
							widthMin = USER_NORMAL;
							heightMin = USER_NORMAL;
						}
						// Formats simples
						else {
							// Image avec une largeur maximale dépassée
							if(widget.options.uploadData.size === SIZE_MAX || widget.options.uploadData.size === SIZE_MAX_WIDTH) {
								widthMax = widget.options.uploadData.width;
							}
							// Image avec une hauteur maximale dépassée
							if(widget.options.uploadData.size === SIZE_MAX || widget.options.uploadData.size === SIZE_MAX_HEIGHT) {
								heightMax = widget.options.uploadData.height;
							}
							// Image avec une largeur minimale dépassée
							if(widget.options.uploadData.size === SIZE_MIN || widget.options.uploadData.size === SIZE_MIN_WIDTH) {
								widthMin = widget.options.uploadData.width;
							}
							// Image avec une hauteur minimale dépassée
							if(widget.options.uploadData.size === SIZE_MIN || widget.options.uploadData.size === SIZE_MIN_HEIGHT) {
								heightMin = widget.options.uploadData.height;
