_spark.template.FORMAT_ADDRESS = 1;
_spark.template.FORMAT_EMAIL = 2;
_spark.template.FORMAT_IBAN = 3;
_spark.template.FORMAT_MONEY = 4;
_spark.template.FORMAT_NUMBER = 5;
_spark.template.FORMAT_PERCENT = 6;
_spark.template.FORMAT_PHONE = 7;
_spark.template.FORMAT_URL = 8;
_spark.template.format = function(value, format, options) {
  options = $.extend(true, {}, options);
  switch (format) {
    case _spark.template.FORMAT_ADDRESS:
      if (value) {
        var address = [];
        if (value.location) {
          address.push(value.location);
        }
        if (value.street1) {
          address.push(value.street1);
        }
        if (value.street2) {
          address.push(value.street2);
        }
        if (value.city) {
          if (value.postal) {
            address.push(value.postal + " " + value.city);
          } else {
            address.push(value.city);
          }
        }
        if (value.country) {
          address.push(SPARK_FILTER_COUNTRY[value.country]);
        }
        return address.join(", ").xss();
      }
      break;
    case _spark.template.FORMAT_EMAIL:
      if (value) {
        value = value.xss();
        options.display = value;
        return _spark.template.format(
          "mailto:" + value,
          _spark.template.FORMAT_URL,
          options
        );
      }
      break;
    case _spark.template.FORMAT_IBAN:
      if (value) {
        return value.match(/.{1,4}/g).join("\xa0");
      }
      break;
    case _spark.template.FORMAT_MONEY:
      if (typeof value === "string") {
        value *= 1;
      }
      value = window.transCurrency(value);
      return value.replaceAll(" ", "\xa0");
      break;
    case _spark.template.FORMAT_NUMBER:
      if (typeof value === "string") {
        value *= 1;
      }
      value = value.toLocaleString(undefined, {
        style: "decimal"
      });
      return value.replaceAll(" ", "\xa0");
      break;
    case _spark.template.FORMAT_PERCENT:
      if (typeof value === "string") {
        value *= 1;
      }
      value /= 100;
      value = value.toLocaleString(undefined, {
        style: "percent",
        minimumFractionDigits: 2
      });
      return value.replaceAll(" ", "\xa0");
      break;
    case _spark.template.FORMAT_PHONE:
      if (value) {
        value = value.toString();
        // Prefix number with a + if it is missing https://gitlab.com/assoconnect/assoconnect/-/issues/16498
        if (value.charAt(0) !== '+') {
          value = '+' + value;
        }
        var link = intlTelInputUtils.formatNumber(
          value,
          null,
          intlTelInputUtils.numberFormat.RFC3966
        );
        options.display = intlTelInputUtils
          .formatNumber(
            value,
            null,
            intlTelInputUtils.numberFormat.INTERNATIONAL
          )
          .replaceAll(" ", "\xa0");
        return _spark.template.format(
          link,
          _spark.template.FORMAT_URL,
          options
        );
      }
      break;
    case _spark.template.FORMAT_URL:
      if (value) {
        var attributes = ['href="' + value.xss() + '"'];
        if (options.target) {
          attributes.push('target="' + options.target.xss() + '"');
          if (options.target === "_blank") {
            attributes.push('rel="noopener"');
          }
        }
        return (
          "<a " +
          attributes.join(" ") +
          ">" +
          (options.display ? options.display : value) +
          "</a>"
        );
      }
      break;
    default:
      console.error("Unknown format: " + format);
  }
  // Chaine vide
  return "";
};

