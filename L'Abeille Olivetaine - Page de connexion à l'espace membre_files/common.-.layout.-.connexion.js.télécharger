        $("<div>")
            .attr("id", widget.element.attr("id") + "DropdownMenu")
            .addClass("dropdownMenu")
            .append(
                $("<div>").append(
                    (function() {
                        if(widget.options.title) {
                            return $("<h2>").text(widget.options.title);
                        }
                    }),
                    $("<ul>").append(dropdownMenuContent)
                )
            )
            // Annule le timer qui cache le menu
            .on("mouseover", function() {
                clearTimeout(timer);
            })
            // Lance le timer pour fermer le menu
            .on("mouseout", function() {
                timer = setTimeout(function() {
                    $("#" + widget.element.attr("id") + "DropdownMenu").hide();
                }, 200);
            })
            .appendTo("body");

        // Actions au clic et au passage sur le widget
        var dropdownMenuDOM = $("#" + widget.element.attr("id") + "DropdownMenu");
        widget.element
            .on("click mouseenter", function() {
                // Calcule des positions
                widget.position();
                // Affiche le menu
                dropdownMenuDOM.show();
            })
            .on("mouseover", function() {
                // Annule le timer qui cache le menu
                clearTimeout(timer);
            })
            .on("mouseout", function() {
                // Lance le timer pour fermer le menu
                timer = setTimeout(function() {
                    dropdownMenuDOM.hide();
                }, 200);
            });

        // Action après resize de la fenêtre
        $(window).on("resize orientationChanged", function() {
            // Calcule des positions
            widget.position();
        });
        // Action après un event click dans le document sauf sur la cible et le menu (pour fermer le menu sur mobile)
        $(document).on("click", function(e) {
            if (
                widget.element.is(e.target) === false
                && widget.element.has(e.target).length === 0
                && dropdownMenuDOM.is(e.target) === false
                && dropdownMenuDOM.has(e.target).length === 0
            ) {
                dropdownMenuDOM.hide();
            }
        });

    },

    position: function () {
        var dropdownMenuDOM = $("#" + this.element.attr("id") + "DropdownMenu");
        var dropdownMenuLeft = 0;
        var dropdownMenuTop = 0;
        // Seulement pour le mode desktop
        if(dropdownMenuDOM.css("minWidth") !== "100%") {
            // Desktop : Inverse le côté d'apparition du menu en fonction de la cible si le menu dépasse par la droite
            if(this.element.offset().left + dropdownMenuDOM.outerWidth() > $(window).width()) {
                dropdownMenuLeft = this.element.offset().left - dropdownMenuDOM.outerWidth() + this.element.outerWidth();
            }
            // Affichage simple
            else {
                dropdownMenuLeft = this.element.offset().left;
            }
        }
        // Inverse le côté d'apparition du menu en fonction de la cible si le menu dépasse par le bas
        if(
            this.element.offset().top > dropdownMenuDOM.outerHeight() // Ignore si l'ofset top est insuffisant #8998
            && this.element.offset().top + dropdownMenuDOM.outerHeight() > $(window).height()
        ) {
            dropdownMenuTop = this.element.offset().top - dropdownMenuDOM.height() - this.element.height();
        }
        // Affichage simple
        else {
            dropdownMenuTop = this.element.offset().top + this.element.outerHeight();
        }
        // Met à jour les positions du menu
        dropdownMenuDOM.css({
            left: dropdownMenuLeft,
            top: dropdownMenuTop
        });
    }

});
