      }
      // Vérification du pays
      else if (iban.substring(0, 2) in SPARK_IBAN_LENGTH === false) {
        return trans("spark.form.iban.helper.country");
      }
      // Vérification de la longueur
      else if (iban.length !== SPARK_IBAN_LENGTH[iban.substring(0, 2)]) {
        return trans("spark.form.iban.helper.length");
