 * @param		{string}		name		Name de l'élément HTML
 * @param		{string}		suffix		Suffixe à retirer
 * @return		{string}
 */
_spark.form.model._removeSuffix = function (name, suffix) {
  if (name.substr(name, -suffix.length) === suffix) {
    name = name.substr(0, -suffix.length);
