$.widget("ui.dialogs", $.ui.dialog, {

    // Pas d'utilisation de hide() et show() car ils ajoutent un display:block aux éléments alors qu'ils sont en display:table-cell

    _create: function(){
        this._super();
        var widget = this;
        var widgetWrapper = widget.element.parent();
        var dialogs = widget.element.find(".dialog");
        // Ajout d'une classe au container
        widget.element.addClass("dialogWrapper row colsMiddle");
        // Ajout des flèches
        // Flèche précédente
        widget.element.prepend(
            $("<div>")
                .addClass(COL1 + " textAlignLeft")
                .css("display", "table") // Fix #10800
                .append(
                    _spark.template._gif("icoBigArrowLeft32Blue dialogPrevious cursorPointer")
                        .on("click", function() {
                            widget.changeDialog("previous")
                        })
                )
        );
        // Flèche suivante
        widget.element.append(
            $("<div>")
                .addClass(COL1 + " textAlignRight")
                .css("display", "none")
                .append(
                    _spark.template._gif("icoBigArrowRight32Blue dialogNext cursorPointer")
                        .on("click", function() {
                            widget.changeDialog("next")
                        })
                )
        );
        // Ajout la div container des points (en dehors de widgetElement pour ne pas géner les cols)
        widgetWrapper.append(
            $("<div>").addClass("dialogDotWrapper")
        );
        // Cache les dialogs
        dialogs.css("display", "none");
        // Affiche la flêche suivant si plus d'une dialog
        if(dialogs.length > 1) {
            widgetWrapper.find(".dialogNext").parent().css("display", "table-cell")
        }
        // Passe en revue les dialogs
        var dialogDotWrapper = widgetWrapper.find(".dialogDotWrapper");
        dialogs.each(function(i) {
            var _this = $(this);
            // Ajout des points
            dialogDotWrapper.append(
                $("<div>")
                    .addClass("dialogDot displayInlineBlock margin5 cursorPointer")
                    .attr("data-index", i)
                    .on("click", function() {
                        widget.changeDialog(i)
                    })
            );
            // Pour le premier dialog
            if(i === 0) {
                // Affiche le premier dialog et ajout du col (+1 car 1 flèche)
                _this.css("display", "table-cell").addClass(COL11);
                // Met en surbrillance le premier point
                widgetWrapper.find(".dialogDot[data-index=0]").addClass("dialogDotCurrent")
            }
            // Pour le dernier dialog
            else if(i === (dialogs.length - 1)) {
                // Ajout du col (+1 car 1 flèche)
                _this.addClass(COL11);
            }
            // Pour les autres
            else {
                _this.addClass(COL10);
            }
            // Ajout d'un data-index aux dialogs
            _this.attr("data-index", i);
        });
    },

    changeDialog: function(actionOrIndex) {
        var dialogCurrent = this.element.find(".dialog:visible");
        var dialogNewIndex;
        if(actionOrIndex === "next") {
            dialogNewIndex = dialogCurrent.data("index") + 1;
        }
        else if(actionOrIndex === "previous") {
            dialogNewIndex = dialogCurrent.data("index") - 1;
        }
        else {
            dialogNewIndex = actionOrIndex;
        }
        // Cache le dialog courant
        dialogCurrent.css("display", "none");
        // Affiche le nouveau dialog
        this.element.find(".dialog[data-index=" + dialogNewIndex + "]").css("display", "table-cell");
        // Affiche/Cache les flèches
        var dialogPrevious = this.element.find(".dialogPrevious");
        var dialogNext = this.element.find(".dialogNext");
        // Cache la flèche précédente pour le premier dialog
        if(dialogNewIndex === 0) {
            dialogPrevious.parent().css("display", "table"); // Fix #10800
            dialogNext.parent().css("display", "table-cell");
        }
        // Cache la flèche suivante pour le dernier dialog
        else if(dialogNewIndex === (this.element.find(".dialog").length - 1)) {
            dialogPrevious.parent().css("display", "table-cell");
            dialogNext.parent().css("display", "none");
        }
        // Sinon affiche les deux flèches
        else {
            dialogPrevious.parent().css("display", "table-cell");
            dialogNext.parent().css("display", "table-cell");
        }
        // Surbrillance des points
        var widgetWrapper = this.element.parent();
        widgetWrapper.find(".dialogDot.dialogDotCurrent").removeClass("dialogDotCurrent");
        widgetWrapper.find(".dialogDot[data-index=" + dialogNewIndex + "]").addClass("dialogDotCurrent");
    }

});
