/**
 *
 * @param vendor
 * @param accountingCategoryId
 * @param account
 * @param paramWrapper
 * @param paramCategory
 * @param paramAccount
 * @param categoriesToSelect
 * @returns {*|jQuery}
 */
_buypacker.form.model.accountingCategoryIdAccount = function(
	vendor,
	accountingCategoryId,
	account,
	paramWrapper,
	paramCategory,
	paramAccount,
	categoriesToSelect
){
	// Valeurs pour les selects
	var selectId = 'accountingCategory' + _spark.misc.random(10);
	var selectValue = null;
	var selectValues = categoriesToSelect[0];
	var categoryIdToAccount = categoriesToSelect[2];

	// Container
	var wrapper = $("<div>").attr("id", paramWrapper);
	// Champ caché pour la catégorie
	var paramCategoryParam = _spark.form.model._helperParam(paramCategory);
	_spark.form.model.hidden(paramCategory, accountingCategoryId).appendTo(wrapper);
	// Champ caché pour le numéro de compte
	var paramAccountParam = _spark.form.model._helperParam(paramAccount);
	_spark.form.model.hidden(paramAccount, account).appendTo(wrapper);
	// Select avec un mix entre les catégories spécifiques au vendor et les catégories génériques
	var selectValuesAsObject = Object.keys(selectValues).map(function(key) {
		return {
			id: key,
			label: selectValues[key]
		};
	}).sort(function(a, b) {
		return a.label.localeCompare(b.label);
	});
	var selectValuesSorted = selectValuesAsObject.map(function(select){
		return select.label;
	});

	// Catégorie sélectionnée
	if(accountingCategoryId) {
		if(accountingCategoryId in selectValues) {
			selectValue = accountingCategoryId;
		}
		else {
			console.error("Unknown category: " + accountingCategoryId);
		}
	}
	// Compte sélectionné
	else if(account) {
		if(- account in selectValues) {
			selectValue = - account;
		}
		else {
			var guessAccountCategory = Object.keys(categoryIdToAccount)
					.find(k=> categoryIdToAccount[k] === account);

			if(guessAccountCategory in selectValues) {
				selectValue = guessAccountCategory;
			} else  {
				console.error("Unknown account: " + account);
			}

		}
	}
	var selectValueSorted = selectValuesAsObject.findIndex(function(selectValueAsObject){
		return selectValueAsObject.id === String(selectValue);
	});

	_spark.form.model.select(selectId, trans("spark.form.model.category"), selectValuesSorted, selectValueSorted)
		.on("change", function() {
			var value = selectValuesAsObject[$(this).find("select").val()].id;
			var categoryIdDOM = $("#" + paramCategoryParam[1]);
			var accountDOM = $("#" + paramAccountParam[1]);
			if(value === "" || value === null){
				categoryIdDOM.val("");
				accountDOM.val("");
			}
			else if(value > 0){
				categoryIdDOM.val(value).trigger("change");
				accountDOM.val(categoryIdToAccount[value]);
			}
			else if(value < 0){
				categoryIdDOM.val("");
				accountDOM.val(- value);
			}
			else{
				console.error("Cas non traité");
			}
		})
		.appendTo(wrapper);
	return wrapper;
};

