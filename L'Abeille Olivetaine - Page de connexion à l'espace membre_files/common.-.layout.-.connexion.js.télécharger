 * @param	string		param		param1 = param2
 * @param	array		param		array($param1, $param2)
 * @return	array
 */
_spark.form.model._helperParam = function (param) {
  if (typeof param !== "object") {
    param = [param, param];
  }
  // Au cas où c'est un id
  param[1] = param[1]
    .toString()
    .replace(/([\[.])([a-zA-Z0-9])/g, function (match, p1, p2) {
      return p2.toUpperCase();
    })
    .replaceAll("]", "");
  return param;
};

/**
