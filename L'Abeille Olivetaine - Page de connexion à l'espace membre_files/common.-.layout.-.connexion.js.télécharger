/**
 * AJAX requests handler
 * @param settings : request settings
 * @param behavior : handler for duplicated requests
 * @returns {XMLHttpRequest}
 */
_spark.ajax = function(settings, behavior){
    // Hash
    var hash = settings.data ? JSON.stringify(settings.data) : "";
    // Vérification
    if(_sparkAjax[settings.url] && _sparkAjax[settings.url].readyState !== XMLHttpRequest.DONE){
        switch(behavior){
            case _spark.AJAX_ABORT:
                _sparkAjax[settings.url].abort();
                break;
            case _spark.AJAX_ALWAYS:
                // On ne fait rien de particulier
                break;
            case _spark.AJAX_ERROR_STRICT:
                throw new Error("Duplicate XMLHttpRequest");
                break;
            case undefined:
            case _spark.AJAX_ERROR_VARY:
                if(_sparkAjaxHash[settings.url] === hash){
                    throw new Error("Duplicate XMLHttpRequest");
                }
                break;
            case _spark.AJAX_IGNORE:
                return _sparkAjax[settings.url];
                break;
            default:
                throw new Error("Unknown behavior: " + behavior);
        }
    }
    // Log du hash
    _sparkAjaxHash[settings.url] = hash;
    // Lancement de la requête
    _sparkAjax[settings.url] = $.ajax(settings);
    // Retour
    return _sparkAjax[settings.url];
};

