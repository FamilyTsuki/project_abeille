_spark.form.postal = {
  check: function (id) {
    var postalDOM = $("#" + id);
    var parser = _spark.form._id.parse(id, "postal");
    var country = $(
      "#" + _spark.form._id.format(parser[1], "country", parser[0])
    ).val();
    var postal = postalDOM.val();
    postal = _spark.form.postal.clean(postal, country);
    // Mise à jour
    postalDOM.val(postal);
    // Vérification
    return _spark.form._error(id, _spark.form.postal.helper(postal, country));
  },
  clean: function (postal, country) {
    postal = postal.trim();
    if (country && SPARK_FILTER_POSTAL[country]) {
      var regexSanitize = new RegExp(
        "[^" + SPARK_FILTER_POSTAL[country][0] + "]"
      );
      postal = postal.replace(regexSanitize, "");
    }
    return postal;
  },
  helper: function (postal, country) {
    postal = _spark.form.postal.clean(postal, country);
    // Un pays a été saisi
    if (country) {
      // Le pays fait partie de la liste
      if (SPARK_FILTER_POSTAL.hasOwnProperty(country)) {
        // Ce pays n'a pas de code postal
        if (SPARK_FILTER_POSTAL[country] === null) {
          // Un code postal a quand même été fourni
          if (postal) {
            return trans("spark.form.postal.helper.unused");
          }
          // Pas d'erreur car aucun code postal saisi
          else {
            return true;
          }
        }
        // SPARK_FILTER_POSTAL[country] contient une regex pour vérifier le code postal
        else {
          // Code postal fourni alors on le vérifie
          if (postal) {
            // Cas spécial - Que des chiffrs
            if (/^\^\[0-9]\{[0-9]}\$$/.test(SPARK_FILTER_POSTAL[country])) {
              postal = postal.replace(/[^\d]*/, "");
            }
            // Cas spécial - GB/CA
            else if (country === "GB" || country === "CA") {
              if (postal.indexOf(" ") === -1) {
                postal =
                  postal.substr(0, postal.length - 3) +
                  " " +
                  postal.substr(postal.length - 3, 3);
              }
            }
            // Vérification
            var regexCheck = new RegExp(SPARK_FILTER_POSTAL[country][1]);
            if (regexCheck.test(postal)) {
              return true;
            } else {
              return trans("spark.form.postal.helper.incorrect");
            }
          }
          // Code postal non saisi => erreur
          else {
            return trans("spark.form.postal.helper.required");
          }
        }
      }
      // Le pays n'est pas dans la liste : il est incorrect
      else {
        return trans("spark.form.postal.helper.country.unknown", {
          country: country,
        });
      }
    }
    // Aucun pays saisi ...
    else {
      // ... mais on a un code postal : sans pays on ne connait pas la règle de vérification
      if (postal) {
        return trans("spark.form.postal.helper.country.required");
      }
      // ... et aucun code postal saisi : on décide arbitrairement de ne pas faire de check
      else {
        return true;
      }
    }
  },
};

_spark.form.selects = {
  /**
   * Contient les différentes données
   */
  data: {},
  /**
   * Met à jour le select suivant
   * @param	{array}			ids		Ids des champs précédents
   * @param	{string}		id		Id du champ en cours
   * @param	{string}		value	Valeur par défaut pour le second
   * @return	void
   */
  update: function (ids, id, value) {
    var select = $("#" + id);
    var selectWrapper = $("#" + id + "Wrapper");
    // Valeur actuelle
    var valueOld = select.val();
    // On vide le champ en cours
    select.text("");
    // On le remplit avec les bonnes valeurs
    var values = _spark.form.selects.data[id];
    for (var i = 0; i < ids.length; i++) {
      values = values[$("#" + ids[i]).val()];
      // Aucune valeur à afficher
      if (!values) {
        selectWrapper.hide();
        return;
      } else {
        selectWrapper.show();
      }
    }
    for (var j = 0; j < values.length; j++) {
      select.append(
        $("<option>").attr("value", values[j][0]).text(values[j][1])
      );
    }
    // On choisit la bonne valeur pour le second
    if (value) {
      select.val(value);
    }
    // Sinon on tente de garder la valeur sélectionnée avant le changement de la liste
    else if (valueOld && valueOld in values) {
      select.val(valueOld);
    }
    // On propage le change
    select.change();
  },
};

