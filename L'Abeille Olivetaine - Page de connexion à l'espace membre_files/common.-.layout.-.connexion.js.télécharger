$(function () {

    /*
     * Ce code est une surcouche JS pour les miniatures
     * Il permet de laisser visible le thumbHover lorsque l'utilisateur ouvre un dropdown menu
     * Il s'ajoute aux règles CSS qui gèrent le hover, il peut donc être désactivé / supprimé sans casser le système de miniature
     */

    var timer = null

    // Ajoute la classe thumbHoverEvent au survole sur un thumbCommon
    $(document).on("mouseover", ".thumbCommon", function() {
        $(".thumbHoverEvent").removeClass("thumbHoverEvent");
        $(this).addClass("thumbHoverEvent");
        clearInterval(timer)
    });

    // Supprime la classe thumbHoverEvent lors du survole ou du click sur un élément qui n'est pas thumbCommon ou thumbHoverEvent
    $(document).on("mouseover click", function(e) {
        if (
            $(".thumbHoverEvent").is(e.target) === false
            && $(".thumbHoverEvent").has(e.target).length === 0
            && $(".dropdownMenu").is(e.target) === false
            && $(".dropdownMenu").has(e.target).length === 0
        ) {
            timer = setTimeout(function() {
                $(".thumbHoverEvent").removeClass("thumbHoverEvent");
            }, 200);
        }
        else {
            clearInterval(timer)
        }
    });
});
$(document).tooltip();

