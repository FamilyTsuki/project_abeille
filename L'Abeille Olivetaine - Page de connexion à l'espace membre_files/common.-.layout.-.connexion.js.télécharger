$(document).ajaxError(function(event, jqXHR, ajaxSettings, thrownError){
	// Requête abandonnées
	if(thrownError === "abort"){
		return;
	}
	// Requête non commencée
	if(jqXHR.readyState === 0) {
		return;
	}

	// Check if the error code is allowed for this request in the ajax settings
	if (ajaxSettings.allowedErrorCodes.length && ajaxSettings.allowedErrorCodes.includes(jqXHR.status)) {
		// Escape and do not throw an error
		return;
	}

	if(403 === jqXHR.status) {
		_spark.template.loading(false);
		_spark.template.alert(trans("jquery.ajax.forbidden"));
		return;
	}

	// On affiche un message d'erreur générique si un autre message n'est pas déjà affiché
	_spark.template.alert(trans("jquery.ajax.error"));
	console.log(trans("jquery.ajax.error"));
	console.trace();
	console.log(arguments);
