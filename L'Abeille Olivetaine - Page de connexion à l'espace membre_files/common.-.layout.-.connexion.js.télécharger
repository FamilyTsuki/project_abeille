         */
        multi: false,
        /**
         * Widget input name
         */
        name: "",
        /**
         * Data to be sent when uploading
         */
        uploadData: {},
        /**
         * Allowed MIME types
         */
        mimes: [],
        /**
         * Max size
         */
        size: 0
    },

    /**
     * Current file input
     */
    input: false,

    /**
     * Browser support file drop
     */
    supportDrop: false,

    /**
     * Browser support File & FileList HTML5 API
     */
    supportFileAPI: false,

    /**
     * Browser support
     * - file transfer with AJAX
     * - File and FileList HTML5 API
     */
    supportMultiple: false,

    /**
     * Browser support "onchange" event on file inputs
     */
    supportOnChange: false,

    /**
     * UID
     */
    uid: 0,

    /**
     * Widget creation
     */
    _create: function(){
        var fileElement = document.createElement("input");
        fileElement.type = "file";
        var divElement = document.createElement("div");
        var widget = this;
        // File && FileList HTML5 API
        this.supportFileAPI = (window.File && window.FileList);
        // drop on div
        this.supportDrop = Boolean(("ondrop" in divElement) && window.addEventListener && this.options.action);
        // onchange in file input
        this.supportOnChange = ("onchange" in fileElement);
        $("#" + this.options.id + "Upload")
            .toggle(!this.supportOnChange)
            .on("click", function(){
                widget.upload();
            });
        // FormData
        this.supportMultiple = Boolean(this.supportFileAPI && window.FormData);
        // Prepare the widget
        this.prepareInput();
        // Drag and drop
        // http://www.thebuzzmedia.com/html5-drag-and-drop-and-file-api-tutorial/
        if(this.supportDrop){
            var dropbox = this.element[0].ownerDocument.getElementById(this.options.id + "Wrapper");
            // We don't use dragenter event to set the class .formUploadDropHover as dragleave is fired right after because of child elements
            dropbox.addEventListener("dragover", function(){
                $("#" + widget.options.id + "Wrapper .formUploadInputWrapper").addClass("formUploadDropHover");
            });
            dropbox.addEventListener("dragleave", function(){
                $("#" + widget.options.id + "Wrapper .formUploadInputWrapper").removeClass("formUploadDropHover");
            });
            dropbox.addEventListener("drop", function(event){
                event.stopPropagation();
                event.preventDefault();
                $("#" + widget.options.id + "Wrapper .formUploadInputWrapper").removeClass("formUploadDropHover");
                if(widget.input && event.dataTransfer.files.length){
                    // Multi files on
                    if(widget.options.multi){
                        widget.upload(event.dataTransfer.files, true);
                    }
                    // Multi files off
                    else{
                        // We limit at just one file in case the user selected two or more
                        widget.upload(Array.prototype.slice.call(event.dataTransfer.files, 0, 1), true);
                    }
                }
            });
        }
        // Existing files && asynchrone
        if(this.options.files && this.options.action){
            for(var i = 0; i < this.options.files.length; i++){
                this.add(this.options.files[i]);
            }
        }
    },

    _checker: function(file, success, error){
        // Limite sur le nombre de fichier
        if($.isNumeric(this.options.multi) && Object.keys(this.options.files).length >= this.options.multi){
            error(trans("spark.form.upload.check.error.limit", {"limit": this.options.multi}));
            return false;
        }
        if(this.supportFileAPI) {
            // Vérification sur la taille
            if (this.options.size && file.size > this.options.size) {
                var prefix = Math.floor(Math.log(this.options.size) / Math.log(1024));
                var units = ["", "ko", "Mo", "Go", "To", "Po"];
                var size = Math.round(this.options.size / Math.pow(1024, prefix) * 100) / 100;
                error(trans("spark.form.upload.check.error.size", {"size": size, "unit": units[prefix]}));
                console.error("File size:" + file.size);
                return false;
            }
            // Vérification sur le type
            if (
                this.options.mimes.length
                && $.inArray(file.type, this.options.mimes) === -1
                && file.type !== "application/x-download"
                && file.type !== "application/octet-stream"
                && file.type !== "binary/octet-stream"
            ) {
                error(trans("spark.form.upload.check.error.type"));
                console.error("File type:" + file.type);
                return false;
            }
        }
        // Succès
        success();
        return true;
    },

    /**
     * Add an existing file
     */
    add: function(file){
        // UID
        var uid = this.uid++;
        // Wrapper
        this.DOMStart(uid)
            .appendTo("#" + this.options.id + "Wrapper");
        this.complete(uid, file);
        // Mode single file
        if(this.options.multi === false && this.input){
            this.input.remove();
            this.input = false;
        }
    },

    /**
     * Upload terminé
     * @param {integer} uid
     * @param {object} file
     */
    complete: function(uid, file) {
        var widget = this;
        var wrapper = $("#" + this.options.id + "_" + uid + "Wrapper");
        // Succès
        if (file) {
            wrapper
                .empty()
                .append(
                    // Hover
                    $("<div>")
                        .attr("id", this.options.id + "_" + uid + "Hover")
                        .addClass("formUploadHover")
                        .append(
                            $("<a>")
                                .attr("href", file.url)
                                .attr("target", "_blank")
                                .append(
                                    _spark.template.button("#" + this.options.id + "_" + uid + "View", trans("spark.template.button.view"), {
                                        "size":  "small",
                                        "color": "green"
                                    })
                                ),
                            _spark.template.button("#" + this.options.id + "_" + uid + "Delete", trans("spark.template.button.delete"), {
                                    "size":  "small",
                                    "color": "red"
                                })
                                .click(function () {
                                    widget.remove(uid);
                                })
                        ),
                    // Icone
                    _spark.template._gif(widget.options.multi ? "icoMultiUpload32Green" : "icoFileUploaded32Color"),
                    // Nom du fichier
                    $("<span>").text(file.name + "." + file.extension),
                    // Afficher les options
                    _spark.template._gif("icoGear16Dark cursorPointer floatRight"),
                    $("<div>").addClass("clearBoth"),
                    // Input caché pour stocker la réponse
                    $("<input>")
                        .attr("type", "hidden")
                        .attr("name", widget.options.name + "[" + file.id + "]")
                        .attr("id", widget.options.id + "_" + file.id)
                        .val(file.secret)
                        .data("file", file)
                );
            // Event
            file.uid = uid;
            this._trigger("complete", null, file);
        }
        // Echec
        else{
            // Chargement
            wrapper.find(".formUploadProgressWrapper").remove();
        }
        // Retour
        return wrapper;
    },

    /**
     * Returns DOM content for error
     */
    DOMError: function(uid){
        var widget = this;
        return $()
            // Message d'erreur
            .add(
                $("<span>").attr("id", this.options.id + "_" + uid + "Error")
            )
            // Supprimer
            .add(
                _spark.template._gif("icoCross16Color cursorPointer floatRight")
                    .click(function(){
                        widget.remove(uid);
                    }),
                $("<div>").addClass("clearBoth")
            );
    },

    /**
     * Returns DOM content for progress
     */
    DOMProgress: function(uid){
        return $("<div>")
            .attr("id", this.options.id + "_" + uid + "ProgressWrapper")
            .addClass("formUploadProgressWrapper")
            .append(
            // Loading if progress is unavailable
            $("<div>").append(
                $("<img>")
                    .attr("src", HOST_SPARK + "/image/ico.load.16.gif")
                    .attr("id", this.options.id + "_" + uid + "Loading"),
                $("<span>")
                    .text(trans("spark.form.upload.DOMProgress.text"))
            ),
            // Progress tipping bar
            $("<div>")
                .attr("id", this.options.id + "_" + uid + "Progress")
                .progressbar({
                    value:	0,
                    max:	1
                })
                .hide()
        );
    },

    /**
     * Wrapper for a new upload
     */
    DOMStart: function(uid, file){
        return $("<div>")
            .attr("id", this.options.id + "_" + uid + "Wrapper")
            .addClass("formUploadFileWrapper")
            .append(
            // Icone
            _spark.template._gif(this.options.multi ? "icoMultiUpload32Green" : "icoFileUploaded32Color"),
            // Lien et nom du fichier
            $("<span>")
                .attr("id", this.options.id + "_" + uid + "Name")
                .text(file ? file.name : ""),
            this.DOMProgress(uid, file),
            this.DOMError(uid)
        );
    },

    /**
     * Prepare the widget for a new file
     */
    prepareInput: function(){
        // New input
        var widget = this;
        this.input = $("<div>")
            .addClass("formUploadInputWrapper")
            .append(
                _spark.template._gif("icoFileUploadArrow32Dark")
            );
        // Add to DOM
        var wrapper = $("#" + this.options.id + "Wrapper", this.element[0].ownerDocument);
        var target = wrapper.find(".formUploadFileWrapper").first();
        if(target.length){
            this.input.insertBefore(target);
        }
        else{
            this.input.appendTo(wrapper);
        }
        // Drag and drop support
        if(this.supportDrop || this.options.action === "") {
            this.input
                .addClass("formUploadDrop")
                .append(
                    $("<span>").text(trans("spark.form.upload.prepare.drop"))
                );
        }
        // onChange support
        if(this.supportOnChange) {
            // http://stackoverflow.com/questions/5191375/a-file-input-button-for-all-browsers-is-this-possible
            this.input.append(
                $("<div>")
                    .addClass("formUploadInput")
                    .append(
                        $("<input>")
                            .attr("type", "file")
                            .attr("accept", this.options.mimes.join(","))
                            .attr("name", (this.options.action ? "uploadFile" : this.options.name) + (this.options.multi ? "[]" : ""))
                            .prop("multiple", this.options.multi && this.supportMultiple)
                            .on("change", function(){
                                widget.upload(this.files, false);
                            }),
                        _spark.template.button(widget.options.id + "Select", trans("spark.form.upload.prepare.button.select"), {
                            className: "formUploadInputButton",
                            size: "small"
                        })
                )
            );
        }
        else{
            this.input.append(
                $("<input>")
                    .attr("type", "file")
                    .attr("accept", this.options.mimes.join(","))
                    .attr("name", this.options.action ? "uploadFile" : this.options.name)
            );
            // Asynchrone mode
            if(this.options.action){
                this.input.append(
                    _spark.template.button(widget.options.id + "Send", trans("spark.template.button.submit"), {
                        size: "small"
                    })
                        .on("click", function(){
                            widget.upload($("input[name='uploadFile']")[0].files, false);
                         })
                );
            }
        }
    },

    /**
     * Update progress
     */
    progress: function(uid, progress){
        // Transfer completed
        if(progress === false){
            $("#" + this.options.id + "_" + uid + "Progress", this.element[0].ownerDocument).hide();
        }
        // Transfer starting
        else if(progress === true){
            $("#" + this.options.id + "_" + uid + "ProgressWrapper", this.element[0].ownerDocument).show();
            $("#" + this.options.id + "_" + uid + "ProgressLoading", this.element[0].ownerDocument).show();
            $("#" + this.options.id + "_" + uid + "Progress", this.element[0].ownerDocument).hide();

        }
        // On going transfer
        else{
            $("#" + this.options.id + "_" + uid + "ProgressWrapper", this.element[0].ownerDocument).show();
            $("#" + this.options.id + "_" + uid + "ProgressLoading", this.element[0].ownerDocument).hide();
            $("#" + this.options.id + "_" + uid + "Progress", this.element[0].ownerDocument)
                .show()
                .progressbar({
                    value:	progress,
                    total:	1
                });
        }
    },

    /**
     * Remove a file
     */
    remove: function(uidOrFilename){
        var widget = this;
        // Uid or filename
        if(typeof(uidOrFilename) === "string") {
            // Remove wrapper
            $("[data-filename='" + uidOrFilename + "']").fadeOut(function(){
                $(this).remove();
                // New input
                if(!widget.options.multi){
                    widget.prepareInput();
                }
                // Clean up the fileNames array so that Forms including this widget can check validation rules correctly
                var fileNameIndex = widget.options.fileNames.indexOf(uidOrFilename);
                if (fileNameIndex > -1) {
                    widget.options.fileNames.splice(fileNameIndex, 1);
                }
                // Emit an event so that we can catch the change with .on("formuploadremove", function() {...})
                widget._trigger("remove", null, uidOrFilename);
            });

        }
        else {
            // Remove wrapper
            $("#" + this.options.id + "_" + uidOrFilename + "Wrapper", this.element[0].ownerDocument).fadeOut(function(){
                $(this).remove();
                // New input
                if(!widget.options.multi){
                    widget.prepareInput();
                }
            });
            // Remove from files list
            var file = this.options.files;
            delete(this.options.files[uidOrFilename]);
            // Event
            this._trigger("remove", null, file);
        }
    },

    /**
     * Reset the input as if no file was uploaded
     */
    reset: function(){
        $("#" + this.options.id + "Wrapper", this.element[0].ownerDocument).find(".formUploadFileWrapper, .formUploadInputWrapper").remove();
        // New input
        this.prepareInput();
    },

    /**
     * Start uploads
     */
    upload: function(files, drop){
        // Asynchrone
        if(this.options.action) {
            // Event
            this._trigger("send");
            // Modern method
            if (this.supportMultiple) {
                var filesWrapper = $("#" + this.options.id + "Wrapper", this.element[0].ownerDocument);
                // Init all files
                var uids = [];
                for (var index = 0; index < files.length; index++) {
                    uids.push(this.uid++);
                    // Create wrapper for the new file
                    this.DOMStart(uids[index], files[index])
                        .appendTo(filesWrapper);
                }
                // Starts first upload
                if (files[0]) {
                    // Input
                    if (this.input && (!drop || this.options.multi === false)){
                        // Hidden
                        this.input.hide();
                        // This file input must not be sent along with the form
                        this.input.appendTo("body");
                        this.input = false;
                    }
                    this.uploadFile(0, uids, files);
                }
            }
            // Legacy
            else {
                var uid = this.uid++;
                // Create wrapper for the new file
                this.DOMStart(uid)
                    .appendTo("#" + this.options.id + "Wrapper");
                // Starts upload
                this.uploadFile(0, [uid]);
            }
            // New input
            if (this.options.multi && !drop) {
                this.prepareInput();
            }
        }
        // Synchrone
        else{
            // Vérification
            var promises = [];
            var errors = [];
            var fileNames = [];
            var widget = this;
            widget.input.find(".icoFileUploadArrow32Dark").removeClass("icoFileUploadArrow32Dark").addClass("icoFilePending32Dark");
            for(var i = 0; i < files.length; i++){
                // Liste des noms de fichiers
                fileNames.push(files[i].name);
                // Deferred
                (function(){
                    var file = files[i];
                    var deferred = $.Deferred();
                    promises.push(deferred);
                    // Vérification
                    widget._checker(file, function(){
                        deferred.resolve();
                    }, function(message){
                        errors.push(file.name + " : " + message);
                        deferred.resolve();
                    });
                })();
            }
            // Fin des vérifications
            $.when.apply($, promises).then(function(){
                // Succès
                if(errors.length === 0) {
                    var inputDOM = widget.input.find(".formUploadInput").find("[type=file]").clone(); // Conserve l'input file
                    widget.input
                        .removeClass("formUploadInputWrapper formUploadDrop")
                        .addClass("formUploadFileWrapper")
                        .attr("data-filename", fileNames.join(","))
                        .empty()
                        .append(
                            inputDOM.hide(),
                            // Hover
                            $("<div>")
                                .addClass("formUploadHover")
                                .append(
                                    _spark.template.button("#" + widget.options.id + "_" + "Delete", trans("spark.template.button.delete"), {
                                        "size":  "small",
                                        "color": "red"
                                    })
                                        .click(function () {
                                            widget.remove(fileNames.join(","));
                                        })
                                ),
                            // Icone
                            _spark.template._gif(widget.options.multi ? "icoMultiUpload32Green" : "icoFileUploaded32Color"),
                            // Nom du fichier
                            $("<span>").text(fileNames.join(", ")),
                            // Afficher les options
                            _spark.template._gif("icoGear16Dark cursorPointer floatRight"),
                            $("<div>").addClass("clearBoth")
                        );
                    widget.options.fileNames = fileNames;
                    // Event
                    widget._trigger("send");
                    // New input
                    if (widget.options.multi && !drop) {
                        widget.prepareInput();
                    }
                }
                // Echec
                else{
                    widget.input.find(".icoFilePending32Dark").removeClass("icoFilePending32Dark").addClass("icoFileUploadArrow32Dark");
                    _spark.template.alert(errors.join("<br>"));
                }
            });
        }
    },

    /**
     * Send a file to the server
     */
    uploadFile: function(index, uids, files){
        // Wrapper
        var wrapper = $("#" + this.options.id + "_" + uids[index] + "Wrapper", this.element[0].ownerDocument);
        // Widget
        var widget = this;
        // Envoi
        var sender = function(){
            // Modern method
            if(widget.supportMultiple){
                // Form data
                var formData = new FormData();
                formData.append("id", widget.options.id);
                formData.append("name", "uploadFile");
                formData.append("field", widget.options.field);
                formData.append("vendorId", widget.options.vendorId);
                formData.append("uploadFile", files[index]); // Must be the last element in case of partial upload
                for(var key in widget.options.uploadData){
                    if(widget.options.uploadData.hasOwnProperty(key)){
                        formData.append(key, widget.options.uploadData[key]);
                    }
                }
                // Requête
                $.ajax({
                    url: widget.options.action,
                    type: "POST",
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: callback,
                    error: callback,
                    // http://stackoverflow.com/a/8758614/1415545
                    xhr: function() {  // Custom XMLHttpRequest
                        var xhr = $.ajaxSettings.xhr();
                        // Check if upload property exists
                        if (xhr.upload) {
                            // Init progress
                            widget.progress(uids[index], 0);
                            // Update progress
                            xhr.upload.addEventListener("progress", function(event){
                                widget.progress(uids[index], event.loaded / event.total);
                            }, false);
                            // Upload completed
                            xhr.upload.addEventListener("load", function(){
                                widget.progress(uids[index], false);
                            }, false);
                        }
                        return xhr;
                    }
                });
            }
            // Legacy
            else{
                // Iframe
                $("<iframe>")
                    .attr("id", widget.options.id + "_" + uids[index] + "Iframe")
                    .attr("name", widget.options.id + "_" + uids[index] + "Iframe")
                    .on("load", function(){
                        var contents = $(this).contents().text();
                        if(contents){
                            callback($.parseJSON(contents));
                        }
                    })
                    // Append must occur after iframe naming
                    .appendTo(wrapper);
                // Form
                $("<form>")
                    .addClass("displayNone")
                    .attr("action", widget.options.action)
                    .attr("target", widget.options.id + "_" + uids[index] + "Iframe")
                    .attr("method", "POST")
                    .attr("enctype", "multipart/form-data")
                    // Bug IE
                    // @link http://stackoverflow.com/a/6278801/1415545
                    // @link http://www.bennadel.com/blog/1273-setting-form-enctype-dynamically-to-multipart-form-data-in-ie-internet-explorer.htm
                    .attr("encoding", "multipart/form-data")
                    .appendTo("body")
                    .append(
                        $("<input>")
                            .attr("type", "text")
                            .attr("name", "name")
                            .attr("value", "uploadFile"),
                        $("<input>")
                            .attr("type", "text")
                            .attr("name", "field")
                            .attr("value", widget.options.field),
                        $("<input>")
                            .attr("type", "text")
                            .attr("name", "id")
                            .attr("value", widget.options.id),
                        (function(data){
                            var inputs = $();
                            for(var key in data){
                                if(data.hasOwnProperty(key)){
                                    inputs = inputs.add(
                                        $("<input>")
                                            .attr("type", "text")
                                            .attr("name", key)
                                            .attr("value", data[key].toString())
                                    );
                                }
                            }
                            return inputs;
                        })(widget.options.uploadData),
                        widget.input
                    )
                    .submit();
                // Input
                widget.input = false;
            }
        };
        // Callback après envoi
        var callback = function(response){
            // Arrêt du chargement
            widget.progress(uids[index], false);
            // Error while parsing response
            if(response.result === undefined){
                response = {
                    result:		false,
                    notices:	{},
                    messages:	{
                        error:	[]
                    }
                };
                response.notices[widget.options.field] = [trans("spark.form.upload.uploadFile.callback.error")];
            }
            // UID
            response.uid = uids[index];
            // Success
            if(response.result){
                // Event
                if(widget._trigger("upload", null, response)) {
                    // Liste des éléments existants
                    widget.options.files[response.uid] = response.file;
                    // Mise à jour de l'affichage
                    widget.complete(response.uid, response.file);
                }
            }
            // Failure
            else{
                // Event
                widget._trigger("upload", null, response);
                // Error
                $("#" + widget.options.id + "_" + response.uid + "Wrapper", widget.element[0].ownerDocument).addClass("formUploadError");
                if(response.notices){
                    var notices = [];
                    for(var key in response.notices){
                        if(response.notices.hasOwnProperty(key)){
                            notices = notices.concat(response.notices[key]);
                        }
                    }
                    $("#" + widget.options.id + "_" + response.uid + "Error", widget.element[0].ownerDocument)
                        .xss(notices.join("\r\n"));
                }
                else if(response.messages.error){
                    $("#" + widget.options.id + "_" + response.uid + "Error", widget.element[0].ownerDocument)
                        .xss(response.messages.error.join("\r\n"));
                }
                // Mise à jour de l'affichage
                widget.complete(response.uid);
            }
            // Next file
            if(widget.supportMultiple){
                if(files[index + 1]){
                    widget.uploadFile(index + 1, uids, files);
                }
            }
        };
        // Vérification & envoi
        if(window.File){
            this._checker(files[index], sender, function(message){
                var response = {
                    result:		false,
                    notices:	{},
                    messages:	{
                        error:	[]
                    }
                };
                response.notices[widget.options.field] = [message];
                return callback(response);
            });
        }
        else{
            sender();
        }
    }
});
