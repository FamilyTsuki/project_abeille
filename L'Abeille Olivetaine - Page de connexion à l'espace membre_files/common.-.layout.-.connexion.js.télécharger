    try {
      const response = await fetch(`${baseUrl}/public/collects/${collectId}/iframe`);
      const data = await response.json();

      Object.entries(data.attributes).forEach(([key, value]) => {
        if (Array.isArray(value)) {
          value = value.join(",");
        }
        Array.from(iframeContainers)[index].setAttribute(
          `data-asc-${key}`,
          value
        );
      });

      // Look for the script tag with the buildId
      let script = document.getElementById(data.buildId);

      if (!script) {
        script = document.createElement("script");
        script.defer = true;
        script.id = data.buildId;
        script.src = `${baseUrl}/public/build/js/iframeSDK.js?${data.buildId}`;
        document.body.appendChild(script);
      }
    } catch (error) {
      console.error("Error fetching data:", error);
    }
  }

  Array.from(iframeContainers).forEach((iframeContainer, index) => {
    const collectId = iframeContainer.getAttribute(`data-collect-id`);

    generateIframeScript(collectId, index);
  });
})();

(() => {
  const iframeContainers = document.querySelectorAll(".iframe-asc-container");

  iframeContainers.forEach((iframeContainer) => {
    const iframe = document.createElement("iframe");
    iframe.src = iframeContainer.getAttribute("data-asc-src");

    // Apply all attributes from iframe container to iframe
    const attributes = Array.from(iframeContainer.attributes);
    attributes.forEach((attribute) => {
      iframe.setAttribute(attribute.name, attribute.value);
    });

    iframe.width = "100%";
    iframe.height = "100%";
    iframe.style.overflow = "hidden";
    iframe.style.border = "0";
    iframe.style.maxHeight = "none";
    iframeContainer.appendChild(iframe);

    window.addEventListener("message", (event) => {
      if (!iframe.dataset.ascOrigins) {
        return;
      }

      const origins = iframe.dataset.ascOrigins.split(",");

      if (origins.some((origin) => origin === event.origin)) {
        if (event.data.action === "iframe.height") {
          iframe.height = event.data.height;
        }
      }
    });
  });
})();
