      })
      .then(function (response) {
        return response.Answer ? true : false;
      })
      .catch(function () {
        // If the service is down, do not check the email
        return true;
      });
  },
  suggest: function (email) {
    var i, tmp;
    var providers = [
      "aol.fr",
      "aol.com",
      "bbox.fr",
      "free.fr",
      "gmail.com",
      "hotmail.fr",
      "hotmail.com",
      "laposte.net",
      "live.fr",
      "live.com",
      "msn.fr",
      "msn.com",
      "orange.fr",
      "sfr.fr",
      "wanadoo.fr",
      "yahoo.fr",
      "yahoo.com",
    ];

    var mailUser = email.substring(0, email.indexOf("@"));
    var mailProvider = email.substring(email.indexOf("@") + 1);
    // Vérification du provider
    var levenshteinProvider = 100; // Distance
    var levenshteinProvider_i = 100; // Indice
    for (i = 0; i < providers.length; i++) {
      tmp = levenshtein(providers[i], mailProvider);
      // Si c\'est plus petit on le garde
      if (tmp < levenshteinProvider) {
        levenshteinProvider = tmp;
        levenshteinProvider_i = i;
      }
    }
    // Suggestion
    if (levenshteinProvider === 1) {
      // Seulement si l\'écart est faible
      var suggest = mailUser + "@";
      // Provider
      if (levenshteinProvider === 1) {
        suggest += providers[levenshteinProvider_i];
      } else {
        suggest += mailProvider;
      }
      return suggest;
    } else {
      return false;
    }
  },
  clean: function (email) {
    // Passage en minuscule
    email = email.toLowerCase();
    // Nettoyage de caractères
    // TODO Sylvain: trouver une meilleure solution pour le
    email = email.replaceAll(
      ["à", "ç", "é", "è", "ë", "ê", "ï", ",", "mailto:", ";", " "],
      ["a", "c", "e", "e", "e", "e", "i", ".", "", ".", ""]
    );
    // Espaces
    email = email.trim();
    // Dernier caractère non correct
    var regexp = /^(.*\.[a-z]{2,4})([^a-z]+)$/;
    email = email.replace(regexp, "$1");
    // Retour
    return email;
  },
  helper: async function (email, required) {
    if (email.length === 0) {
      if (required) {
        return trans("spark.form.mail.helper.empty");
      } else {
        return true;
      }
    }
    // Présence de caractères interdits
    var regexp = /^([a-z0-9!#$%&'*+/=?^_`{|}~\.(),:;<>@\[\\\]-]+)$/i;
    if (regexp.test(email) !== true) {
      return trans("spark.form.mail.helper.invalid");
    }
    // Double ..
    if (email.indexOf("..") > -1) {
      return trans("spark.form.mail.helper.invalid");
    }
    // Est-ce qu'il y a un @
    email = email.split("@");
    if (email.length !== 2) {
      return trans("spark.form.mail.helper.at");
    }

    var input = document.createElement("input");
    input.type = "email";
    input.value = email[0] + "@" + email[1];
    // Vérification en HTML 5
    if (input.checkValidity && input.checkValidity() === false) {
      return trans("spark.form.mail.helper.incorrect");
    }
    // Vérification classique en backup
    // On vérifie la 1ère partie
    if (SPARK_FILTER_MAIL_USER.test(email[0]) !== true) {
      return trans("spark.form.mail.helper.incorrect");
    }
    // On vérifie la 2nde partie
    if (SPARK_FILTER_MAIL_ISP.test(email[1]) !== true) {
      return trans("spark.form.mail.helper.incorrect");
    }
    // Check DNS
    var checkDns = await _spark.form.mail.checkDns(email[0] + "@" + email[1]);
    if (!checkDns) {
      return trans("spark.form.mail.helper.domain");
    }
    // Email valide
    return true;
  },

