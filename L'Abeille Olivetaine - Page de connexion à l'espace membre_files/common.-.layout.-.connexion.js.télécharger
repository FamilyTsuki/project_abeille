_spark.form.model._select = function (values, current, forceChoice) {
  var options = [];
  var notFound = values[current] === undefined;
  if ((notFound && forceChoice !== false) || forceChoice === true) {
    options.push(
      $("<option>")
        .attr("value", "")
        .prop("selected", notFound)
        .text(window.trans("form.select.placeholder"))
    );
  }
  var keys = Object.keys(values);
  for (var i = 0; i < keys.length; i++) {
    // Optgroup
    if (typeof values[keys[i]] === "object") {
      options.push(
        $("<optgroup>")
          .attr("label", keys[i])
          .append(_spark.form.model._select(values[keys[i]], current, false))
      );
    }
    // Option
    else {
      var selected;
      if (current === null) {
        selected = keys[i] === "";
      } else if (typeof current === "boolean") {
        selected = Boolean(keys[i]) === current;
      } else if ($.isNumeric(current) && $.isNumeric(keys[i])) {
        selected = current * 1 === keys[i] * 1;
      } else {
        selected = current === keys[i];
      }
      options.push(
        $("<option>")
          .attr("value", keys[i])
          .prop("selected", selected)
          .text(values[keys[i]])
      );
    }
  }
  return options;
};

