/** Chargement
 * @param {(string|boolean)}  loading
 * false  = fermeture
 * true   = ouverture avec un message par défaut
 * string = ouverture avec le message indiqué
 * @param {boolean} unskippable
 * @param {number | null} progress
 * @returns {boolean}
 */
_spark.template.loading = function(loading, unskippable = false, progress = null) {
  var loadingDOM = $("#sparkTemplateLoading");
  // Appel sans argument
  if (arguments.length === 0) {
    return Boolean(loadingDOM.length && loadingDOM.dialog("isOpen"));
  }
  // Ouverture
  else if (loading) {
    // Chargement déjà en cours
    if (loadingDOM.length) {
      // Affichage de la lightbox
      if (loadingDOM.dialog("isOpen") === false) {
        loadingDOM.dialog("open");
      }
      // Progression
      if (progress) {
        $("#sparkTemplateLoadingProgress").text(
          Math.round(progress * 100) + "%"
        );
      }
      // Retour
      return false;
    }
    // Message par défaut
    if (loading === true) {
      loading = trans("spark.template.loading.text");
    }
    // Création de l'élément
    loadingDOM = $("<div>")
      .attr("id", "sparkTemplateLoading")
      .css("padding-top", "50px")
      .addClass("textAlignCenter")
      .append(
        $("<div>").append(
          $("<img>")
            .attr({
              width: "32px",
              height: "32px",
              src: HOST_SPARK + "/image/ico.load.32.gif"
            })
            .addClass("valignMiddle")
            .css("margin-right", "10px"),
          $("<span>").text(loading)
        ),
        $("<div>").attr("id", "sparkTemplateLoadingProgress")
      )
      // Ajout à la page
      .appendTo("body")
      // Ouverture
      .dialog({
        height: 150,
        dialogClass: unskippable ? "no-close" : "",
      });
  }
  // Fermeture
  else {
    loadingDOM.dialog("close").remove();
  }
};

/**
 * Notification
 * @param	{boolean}	status	false	= Ferme la notification
 *								true	= Ouvre la notification
 */
_spark.template.notification = function(status) {
  var notificationDOM = $("#sparkTemplateNotification");
  // Fermeture
  if (status === false) {
    notificationDOM.fadeOut(function() {
      $(this).remove();
    });
  }
  // Ouverture
  else if (notificationDOM.length === 0) {
    // Création de l'élément
    notificationDOM = $("<div>")
      .attr("id", "sparkTemplateNotification")
      .addClass("backgroundLarge backgroundGreenLight colorGreen displayNone")
      .append(
        _spark.template._gif("icoCheck16Color marginRight10 valignMiddle"),
          $("<span>").text(trans("spark.template.notification.save"))
      )
      .appendTo("body")
      .fadeIn(function() {
        setTimeout(function() {
          _spark.template.notification(false);
        }, 4000);
      });
  }
};

/**
 * Lightbox de prompt user
 * Equivalent de la fonction Javascript prompt
 */
_spark.template.prompt = function(
  body,
  textarea,
  callback,
  prefill,
  ok,
  cancel
) {
  // Reset du prompt
  var promptDOM = $("#sparkTemplatePrompt");
  // Promp non existant
  if (promptDOM.length) {
    promptDOM.remove();
  }
  promptDOM = $("<div>")
    // Création
    .attr("id", "sparkTemplatePrompt")
    .hide()
    .appendTo("body")
    .append(
      _spark.form.model[textarea ? "textarea" : "text"](
        "sparkTemplatePromptInput",
        body,
        prefill
      )
    )
    // Ouverture
    .dialog({
      buttons: [
        {
          text: cancel ? cancel : trans("spark.template.button.cancel"),
          click: function() {
            promptDOM.dialog("close");
            callback.call(null, false);
          }
        },
        {
          text: ok ? ok : trans("spark.template.button.continue"),
          color: "orange",
          click: function() {
            promptDOM.dialog("close");
            callback.call(
              null,
              $("#sparkTemplatePromptInput")
                .val()
                .trim()
            );
          }
        }
      ]
    });
};

$.widget("template.accordion", { 

    options: {
        start: 0,
        lock: false,
        toggleButton: true
    },

    _create: function() {
        var widget = this;
        
        // Traite le container
        widget.element.addClass("accordion");

        // Traite les titres h2 de premier niveau dans les div .accordionContent
        widget.element.find(".accordionContent > h2").each(function (index) {
            var _this = $(this);
            var _thisText = _this.text();
            var content = _this.parents(".accordionContent");
            // Ajoute un data-id aux .accordionContent (utile pour les aides)
            content.attr("data-id", index + 1);
            _this
                .addClass("accordionTitleWrapper")
                .empty()
                .append(function(){
                    let dom = [];
                    dom.push($("<span>").addClass("accordionTitleNumber").text(index + 1));
                    dom.push($("<span>").addClass("accordionTitle").text(_thisText));
                    if (widget.options.toggleButton) {
                        dom.push(_spark.template.button(
                            "toggle" + index,
                            trans("spark.template.accordion.button.title"), {
                                className: "accordionTitleButton",
                                size: "small",
                                color: "grey"
                            })
                        );
                    }
                    return dom;
                });
            // Supprime les effets de hover et autres pour les accordéons suivants celui de départ
            if(index > widget.options.start && widget.options.lock) {
                _this.addClass("accordionLock");
            }
            // Ouvre un contenu de l'accordéon au clic
            _this.on("click", function() {
                if(_this.hasClass("accordionLock") === false || index <= widget.options.start) {
                    widget.open(index);
                }
            });
            // Ouvre le contenu par défaut
            if(index === widget.options.start) {
                widget.open(index);
            }
        });

        // Check des notices après chargement de la page + 0.3s afin de détecter les notices ajoutées en JS (fix #11320)
        $(document).ready(function(){
            setTimeout(function(){
                widget.element.find(".accordionContent").each(function (index) {
                    var _this = $(this);
                    // Au moins une notice trouvée
                    if(_this.find(".notice:not(:empty)").length) {
                        _this.addClass("accordionNotice");
                        _this.find(".accordionTitleNumber").text("!");
                    }
                });
            }, 300);
        });
    },

    open: function(index, callback) {
        var accordionOpen = $(".accordionOpen");
        var accordionClose = $(".accordionClose");
        if(accordionOpen.eq(index).is(":visible") === false) {
            // Supprime la couleur des accordéons en couleur
            $(".accordionColor").removeClass("accordionColor");
            // Ajoute de la couleur à l'accordéon demandé
            $(".accordionContent").eq(index).addClass("accordionColor");
            // Cache les contenus d'ouverture
            accordionOpen.slideUp();
            // Affiche le contenu d'ouverture de la partie demandée
            accordionOpen.eq(index).slideDown(function() {
                // Scroll vers le contenu d'ouverture de la partie demandée
                return $("html, body").scrollTo(accordionOpen.eq(index), {
                    duration: 0,
                    offsetTop: 100
                }, callback);
            });
            // Affiche les contenus de fermeture
            accordionClose.slideDown();
            // Cache le contenu de fermeture de la partie demandée
            accordionClose.eq(index).slideUp();
            // Affiche les boutons d'affichage
            $(".accordionTitleButton").show();
            // Cache le bouton d'affichage et débloque la partie demandée
            $("#toggle" + index + "Button")
                .hide()
                .parents(".accordionTitleWrapper").removeClass("accordionLock");
        }
    }

});
