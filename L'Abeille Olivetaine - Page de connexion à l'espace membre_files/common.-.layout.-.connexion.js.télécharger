        // Présence d'un titre
        if(this.options.title){
            return this._super();
        }
        // Absence d'un titre mais présence de la croix de fermeture
        else if(!this.options.buttons || this.options.buttons.length === 0){
            this.uiDialogTitlebar = $();
            this.uiDialogTitlebarClose = $("<div>").addClass("ui-icon-closethick").append(_spark.template._gif("icoCross16Color")).prependTo(this.uiDialog);
                this._on(this.uiDialogTitlebarClose, {
                    click: function(event) {
                        event.preventDefault();
                        this.close(event);
