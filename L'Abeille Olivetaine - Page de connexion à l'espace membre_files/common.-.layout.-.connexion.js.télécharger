/**
 * Simulate an HTTP redirect
 * @param	{string}		url			Url to go
 * @param	{string}		method		GET or POST
 * @param	{object}		data		Data to send
 * @param	{boolean}		replace		Replace current page in browser history
 */
_spark.redirect = function(url, method, data, replace){
    // Méthode par défaut
    if(!method){
        method = "GET";
    }
    // Données par défaut
    if(!data){
        data = {};
    }
    // URL
    if(url.substr(0, 4) !== "http" && url.substr(0, 2) != "//"){
        url = url;
    }
    // Redirection en GET
    if(method === "GET"){
        if(Object.keys(data).length){
            url += "?" + $.param(data);
        }
        // http://stackoverflow.com/a/506004/1415545
        if(replace){
            return window.location.replace(url);
        }
        else{
            return window.location.href = url;
        }
    }
    // Redirection en POST
    else if(method === "POST"){
        var form = $("<form>")
            .attr("action", url)
            .attr("method", "POST")
            .addClass("displayNone")
            .appendTo("body"); // Bug #3080 sous Firefox
        // Ajout des champs au formulaire
        data = _spark.redirectHelper(data);
        var appender = function(start){
            for(var i = start; i < data[0].length; i++){
                // Ajout au DOM
                $("<textarea>")
                    .attr("name", data[0][i])
                    .text(data[1][i])
                    .appendTo(form);
                // Arrêt
                if(i % 50 === 49){
                    window.setTimeout(function(){
                        appender(i + 1);
                    }, 1);
                    return;
                }
            }
            // Soumission du formulaire
            form.submit();
        };
        appender(0);
    }
    // Redirection inconnue
    else{
        console.error("Unknow redirect method: " + method);
    }
};

_spark.redirectHelper = function (data, name){
    var i,
        _name,
        keys = [],
        values = [],
        result;

    // Valeur par défaut
    if(!name){
        name = "";
    }

    // C'est un tableau
    if($.isArray(data)){
        // Un tableau ne peut pas être le 1er appel de _spark.redirectHelper
        _name = name + "[]";
        for(i = 0; i < data.length; i++){
            result = _spark.redirectHelper(data[i], _name);
            keys = keys.concat(result[0]);
            values = values.concat(result[1]);
        }
        return [keys, values];
    }

    // C'est un objet
    else if(typeof data === "object"){
        // On passe en revue l'objet
        var dataKeys = Object.keys(data);
        for(i = 0; i < dataKeys.length; i++){
            if(name){
                _name = name + "[" + dataKeys[i] + "]";
            }
            else{
                _name = dataKeys[i];
            }
            result = _spark.redirectHelper(data[dataKeys[i]], _name);
            keys = keys.concat(result[0]);
            values = values.concat(result[1]);
        }
        return [keys, values];
    }

    // Par défaut
    else{
        // Ajout à la liste
        return [[name], [data]];
    }
};

