      var iso3166;
      for (iso3166 in SPARK_FILTER_COUNTRY_FR) {
        if (SPARK_FILTER_COUNTRY_FR.hasOwnProperty(iso3166)) {
          _spark.form.country._locales[
            _spark.form.country.clean(
              SPARK_FILTER_COUNTRY_FR[iso3166].toLowerCase()
            )
          ] = iso3166;
        }
      }
      for (iso3166 in SPARK_FILTER_COUNTRY_EN) {
        if (SPARK_FILTER_COUNTRY_EN.hasOwnProperty(iso3166)) {
          _spark.form.country._locales[
            _spark.form.country.clean(
              SPARK_FILTER_COUNTRY_EN[iso3166].toLowerCase()
            )
          ] = iso3166;
        }
      }
    }
    return _spark.form.country._locales;
  },
  suggest: function (country) {
    var _levenshtein = 100;
    var _iso3166;
    var tmp;
    country = country.toLowerCase();
    var locales = _spark.form.country.locales();
    for (var locale in locales) {
      if (locales.hasOwnProperty(locale)) {
        tmp = levenshtein(country, locale);
        if (tmp < _levenshtein) {
          _iso3166 = locales[locale];
          _levenshtein = tmp;
        }
      }
    }
    // Une orthographe proche a été trouvée
    if (_iso3166 && _levenshtein < 3) {
      return _iso3166;
    }
    // Aucun résultat
    else {
      return false;
    }
  },
  clean: function (country) {
    country = country.replaceAll("-", " ").trim();
    // Return 2-letters ISO code
    if (country.length === 2) {
      return country.toUpperCase();
    }
    // Return ISO code from locales() list
    var locales = _spark.form.country.locales();
    if (country.toLowerCase() in locales) {
      return locales[country.toLowerCase()];
    }
    // Else return country name as entered by the user
    return country;
  },
  helper: function (country) {
    if (country) {
      // ISO3166 validation
      if (Boolean(SPARK_FILTER_COUNTRY[country])) {
        return true;
      }
      // If not ISO3166, return error message
      return trans("spark.form.country.helper.incorrect");
    }
    return true;
  },
};

